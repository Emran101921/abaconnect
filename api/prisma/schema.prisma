// BloomOra therapy marketplace – Prisma 7 schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  PARENT
  THERAPIST
  AGENCY_ADMIN
  PLATFORM_ADMIN
  BILLING_STAFF
  COMPLIANCE_AUDITOR
  SUPPORT_STAFF
}

enum TherapyType {
  ABA
  SPEECH
  OCCUPATIONAL
  PHYSICAL
  EARLY_INTERVENTION
  BEHAVIORAL_CONSULTATION
  PARENT_TRAINING
  DEVELOPMENTAL_EVALUATION
}

enum AppointmentStatus {
  REQUESTED
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
  PENDING_DOCUMENTATION
}

enum DocumentType {
  CONSENT_FORM
  INSURANCE_CARD
  IEP
  EVALUATION_REPORT
  TREATMENT_PLAN
  PROGRESS_REPORT
  LICENSE
  CERTIFICATION
  SOAP_NOTE
  OTHER
}

enum MessageChannel {
  IN_APP
  SMS
  EMAIL
  PUSH
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
  CANCELLED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  PENDING
  UNDER_REVIEW
  APPROVED
  DENIED
  APPEALED
  PAID
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  CLOSED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  EXPORT
  ACCESS_DENIED
  CONSENT_GRANTED
  CONSENT_REVOKED
  FILE_UPLOADED
  FILE_DOWNLOADED
  NOTE_CREATED
  NOTE_EDITED
  CLAIM_CREATED
  CLAIM_SUBMITTED
  CLAIM_RESUBMITTED
  PERMISSION_CHANGED
  USER_INVITED
  USER_DISABLED
  REPORT_EXPORTED
  PAYMENT_EVENT
  MESSAGE_SENT
  ARCHIVE
  MARKETPLACE_REQUEST_VIEWED
  MARKETPLACE_INTEREST_SUBMITTED
  MARKETPLACE_INTEREST_REJECTED
  MARKETPLACE_IDENTIFIABLE_SHARED
}

enum MarketplaceRequestStatus {
  DRAFT
  ACTIVE
  PAUSED
  MATCHED
  CLOSED
}

enum MarketplaceInterestStatus {
  PENDING_PARENT_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MarketplaceConsentType {
  ANONYMOUS_MARKETPLACE_POSTING
  SHARE_IDENTIFIABLE_INFO
  SHARE_DOCUMENTS
  REVOKE_CONSENT
}

enum MarketplaceUrgency {
  ROUTINE
  SOON
  URGENT
}

enum MarketplaceAuthorizationStatus {
  PARENT_SCREENING_ONLY
  EVALUATION_NEEDED
  SERVICE_AUTHORIZED
  IFSP_AVAILABLE_AFTER_CONSENT
}

enum MarketplaceLocationType {
  HOME
  DAYCARE
  CLINIC
  TELEHEALTH
  SCHOOL
  COMMUNITY
}

enum MarketplaceAgeRange {
  MONTHS_0_12
  MONTHS_13_24
  MONTHS_25_36
  YEARS_3_5
  YEARS_6_8
  YEARS_9_12
  YEARS_13_PLUS
}

enum MarketplaceServiceCategory {
  SPEECH
  OCCUPATIONAL
  PHYSICAL
  ABA
  SPECIAL_INSTRUCTION
  EVALUATION
  NURSING
  FEEDING
  SOCIAL_WORK
  SERVICE_COORDINATION
  OTHER
}

enum ProviderMarketplaceAccountType {
  THERAPIST
  AGENCY
}

enum ProviderMarketplaceVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum ComplianceDocumentType {
  PRIVACY_POLICY
  TERMS_OF_USE
  HIPAA_NOTICE
  CONSENT_FORM
  DATA_RETENTION_POLICY
  BREACH_NOTIFICATION_POLICY
  CONTACT_COMPLIANCE_OFFICER
}

enum ProviderOnboardingStatus {
  PENDING
  IN_REVIEW
  APPROVED
  SUSPENDED
  INACTIVE
}

enum PrivacyRightsRequestType {
  RECORD_ACCESS
  CORRECTION
  RESTRICTION
  CONFIDENTIAL_COMMUNICATION
  ACCOUNTING_OF_DISCLOSURES
  CONTACT_PRIVACY_OFFICER
  DATA_DELETION
}

enum PrivacyRightsRequestStatus {
  NEW
  IN_REVIEW
  COMPLETED
  DENIED
  NEEDS_MORE_INFO
}

enum SecurityEventSeverity {
  INFO
  WARNING
  CRITICAL
}

enum BadgeType {
  VERIFIED_LICENSE
  BACKGROUND_CHECK
  TOP_RATED
  HIPAA_COMPLIANT
  INSURANCE_ACCEPTED
  YEARS_EXPERIENCE
  EARLY_INTERVENTION_SPECIALIST
}

enum LocationType {
  IN_HOME
  CLINIC
  SCHOOL
  TELEHEALTH
  COMMUNITY
}

enum AgencyTherapistStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

// ---------------------------------------------------------------------------
// Multi-tenant
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  domain    String?  @unique
  settings  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  parents              Parent[]
  children             Child[]
  therapists           Therapist[]
  agencies             Agency[]
  appointments         Appointment[]
  sessions             Session[]
  documents            Document[]
  messageThreads       MessageThread[]
  notifications        Notification[]
  payments             Payment[]
  payouts              Payout[]
  insuranceClaims      InsuranceClaim[]
  complaints           Complaint[]
  disputes             Dispute[]
  auditLogs            AuditLog[]
  hipaaConsents        HipaaConsent[]
  privacyNoticeVersions PrivacyNoticeVersion[]
  hipaaNoticeAcknowledgments HipaaNoticeAcknowledgment[]
  privacyRightsRequests PrivacyRightsRequest[]
  analyticsSnapshots   AnalyticsSnapshot[]
  screeningTemplates   ScreeningTemplate[]
  screeningResponses   ScreeningResponse[]
  treatmentPlans       TreatmentPlan[]
  telehealthSessions   TelehealthSession[]
  locationEvents       LocationEvent[]
  serviceLogs          ServiceLog[]
  providerBadges       ProviderBadge[]
  securityEvents       SecurityEvent[]
  complianceDocuments  ComplianceDocument[]
  complianceDocumentAcceptances ComplianceDocumentAcceptance[]
  claimEditHistories   ClaimEditHistory[]
  marketplaceRequests  MarketplaceRequest[]
  marketplaceInterests MarketplaceInterest[]
  marketplaceConsents  MarketplaceConsentRecord[]
  providerMarketplaceProfiles ProviderMarketplaceProfile[]
  marketplaceSavedSearches MarketplaceSavedSearch[]
  marketplaceReports   MarketplaceReport[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Users & profiles
// ---------------------------------------------------------------------------

model User {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  email           String
  passwordHash    String    @map("password_hash")
  role            UserRole
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?
  avatarUrl       String?   @map("avatar_url")
  isActive        Boolean   @default(true) @map("is_active")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  mfaSecret       String?   @map("mfa_secret")
  mfaEnabled      Boolean   @default(false) @map("mfa_enabled")
  tokenVersion        Int       @default(0) @map("token_version")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  refreshTokens         RefreshToken[]
  securityEvents        SecurityEvent[]
  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent                Parent?
  therapist             Therapist?
  devices               UserDevice[]
  authDevices           AuthDevice[]
  sentMessages          Message[]             @relation("MessageSender")
  messageParticipants   MessageParticipant[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  hipaaConsents         HipaaConsent[]
  hipaaNoticeAcknowledgments HipaaNoticeAcknowledgment[]
  privacyRightsRequests PrivacyRightsRequest[]
  privacyNoticeVersionsCreated PrivacyNoticeVersion[] @relation("NoticeCreatedBy")
  documentAccessLogs    DocumentAccessLog[]
  authoredSoapNotes     SoapNote[]            @relation("SoapNoteAuthor")
  authoredProgressNotes ProgressNote[]        @relation("ProgressNoteAuthor")
  authoredTreatmentPlans TreatmentPlan[]      @relation("TreatmentPlanAuthor")
  reviewsWritten        Review[]              @relation("ReviewAuthor")
  complaintsFiled       Complaint[]           @relation("ComplaintReporter")
  complaintsAssigned    Complaint[]           @relation("ComplaintAssignee")
  disputesOpened        Dispute[]             @relation("DisputeOpener")
  complianceDocumentsCreated ComplianceDocument[] @relation("ComplianceDocCreatedBy")
  complianceDocumentAcceptances ComplianceDocumentAcceptance[]
  claimsCreated         InsuranceClaim[]      @relation("ClaimCreatedBy")
  claimsSubmitted       InsuranceClaim[]      @relation("ClaimSubmittedBy")
  claimEdits            ClaimEditHistory[]    @relation("ClaimEditor")
  therapistsApproved    Therapist[]           @relation("TherapistApprovedBy")
  marketplaceRequestsCreated MarketplaceRequest[] @relation("MarketplaceRequestParentUser")
  marketplaceConsentsGranted MarketplaceConsentRecord[] @relation("MarketplaceConsentParentUser")
  providerMarketplaceProfile ProviderMarketplaceProfile?
  marketplaceSavedSearches MarketplaceSavedSearch[]
  marketplaceReportsFiled MarketplaceReport[] @relation("MarketplaceReportReporter")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([role])
  @@map("users")
}

model UserDevice {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  deviceToken String   @map("device_token")
  platform    String
  appVersion  String?  @map("app_version")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceToken])
  @@index([userId])
  @@map("user_devices")
}

/// Tracks the physical devices a user authenticates from for MFA/security.
/// Distinct from UserDevice (push tokens): this powers new-device detection,
/// device-bound MFA, and IP/location stamping of auth events.
model AuthDevice {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  deviceId      String    @map("device_id")
  deviceModel   String?   @map("device_model")
  platform      String?
  osVersion     String?   @map("os_version")
  trusted       Boolean   @default(false)
  lastIp        String?   @map("last_ip")
  lastLocation  String?   @map("last_location")
  lastLatitude  Decimal?  @map("last_latitude") @db.Decimal(10, 7)
  lastLongitude Decimal?  @map("last_longitude") @db.Decimal(10, 7)
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt    DateTime  @default(now()) @map("last_seen_at")
  mfaVerifiedAt DateTime? @map("mfa_verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("auth_devices")
}

model Parent {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @map("user_id") @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  addressLine1           String?  @map("address_line1")
  addressLine2           String?  @map("address_line2")
  city                   String?
  state                  String?
  zipCode                String?  @map("zip_code")
  latitude               Decimal? @db.Decimal(10, 7)
  longitude              Decimal? @db.Decimal(10, 7)
  emergencyContactName   String?  @map("emergency_contact_name")
  emergencyContactPhone  String?  @map("emergency_contact_phone")
  insuranceProvider      String?  @map("insurance_provider")
  insuranceMemberId      String?  @map("insurance_member_id")
  insuranceGroupNumber   String?  @map("insurance_group_number")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  children             Child[]
  appointments         Appointment[]
  screeningResponses   ScreeningResponse[]
  payments             Payment[]
  insuranceClaims      InsuranceClaim[]
  reviews              Review[]
  complaints           Complaint[]
  disputes             Dispute[]

  @@index([tenantId])
  @@map("parents")
}

// PHI fields on Child: guardianPhone, guardianEmail, addressLine1, zipCode,
// pediatricianName, insuranceType (see AuditService for access logging).
model Child {
  id             String   @id @default(uuid()) @db.Uuid
  parentId       String   @map("parent_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  dateOfBirth    DateTime @map("date_of_birth") @db.Date
  gender         String?
  primaryLanguage       String?  @map("primary_language")
  guardianName          String?  @map("guardian_name")
  guardianPhone         String?  @map("guardian_phone")
  guardianEmail         String?  @map("guardian_email")
  addressLine1          String?  @map("address_line1")
  zipCode               String?  @map("zip_code")
  pediatricianName      String?  @map("pediatrician_name")
  insuranceType         String?  @map("insurance_type")
  hadEarlyIntervention  Boolean? @map("had_early_intervention")
  diagnosisCodes String[] @default([]) @map("diagnosis_codes")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  parent             Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments       Appointment[]
  sessions           Session[]
  screeningResponses ScreeningResponse[]
  treatmentPlans     TreatmentPlan[]
  documents          Document[]
  insuranceClaims    InsuranceClaim[]
  serviceLogs        ServiceLog[]
  marketplaceRequests MarketplaceRequest[]
  marketplaceConsents MarketplaceConsentRecord[]

  ageRange           MarketplaceAgeRange? @map("age_range")
  city               String?
  state              String?

  @@index([parentId])
  @@index([tenantId])
  @@map("children")
}

// ---------------------------------------------------------------------------
// Screenings
// ---------------------------------------------------------------------------

model ScreeningTemplate {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  name         String
  description  String?
  therapyType  TherapyType @map("therapy_type")
  questions    Json        @default("[]")
  scoringRules Json        @default("{}") @map("scoring_rules")
  version      Int         @default(1)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responses ScreeningResponse[]

  @@index([tenantId])
  @@index([therapyType])
  @@map("screening_templates")
}

model ScreeningResponse {
  id               String    @id @default(uuid()) @db.Uuid
  templateId       String    @map("template_id") @db.Uuid
  childId          String    @map("child_id") @db.Uuid
  parentId         String    @map("parent_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  responses        Json      @default("{}")
  score            Decimal?  @db.Decimal(8, 2)
  riskLevel        String?   @map("risk_level")
  recommendations  Json      @default("[]")
  isDraft          Boolean   @default(false) @map("is_draft")
  consentGrantedAt       DateTime? @map("consent_granted_at")
  evaluationRequestedAt  DateTime? @map("evaluation_requested_at")
  concernTags            Json      @default("[]") @map("concern_tags")
  suggestedServiceCategories Json @default("[]") @map("suggested_service_categories")
  disclaimerAccepted     Boolean   @default(false) @map("disclaimer_accepted")
  completedAt            DateTime  @default(now()) @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  template ScreeningTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  child    Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent   Parent            @relation(fields: [parentId], references: [id], onDelete: Cascade)
  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marketplaceRequests MarketplaceRequest[]

  @@index([templateId])
  @@index([childId])
  @@index([parentId])
  @@index([tenantId])
  @@map("screening_responses")
}

// ---------------------------------------------------------------------------
// Providers
// ---------------------------------------------------------------------------

model Therapist {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @unique @map("user_id") @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  npi               String?       @map("npi")
  licenseNumber     String?       @map("license_number")
  licenseState      String?       @map("license_state")
  licenseExpiry     DateTime?     @map("license_expiry") @db.Date
  therapyTypes      TherapyType[] @default([]) @map("therapy_types")
  bio               String?
  yearsExperience   Int?          @map("years_experience")
  hourlyRate        Decimal?      @map("hourly_rate") @db.Decimal(10, 2)
  serviceRadiusKm   Decimal?      @map("service_radius_km") @db.Decimal(8, 2)
  addressLine1      String?       @map("address_line1")
  addressLine2      String?       @map("address_line2")
  city              String?
  state             String?
  zipCode           String?       @map("zip_code")
  latitude          Decimal?      @db.Decimal(10, 7)
  longitude         Decimal?      @db.Decimal(10, 7)
  isVerified        Boolean       @default(false) @map("is_verified")
  isAcceptingClients Boolean      @default(true) @map("is_accepting_clients")
  ratingAverage     Decimal       @default(0) @map("rating_average") @db.Decimal(3, 2)
  ratingCount       Int           @default(0) @map("rating_count")
  stripeAccountId   String?       @map("stripe_account_id")
  taxId             String?       @map("tax_id")
  backgroundCheckStatus String?     @map("background_check_status")
  backgroundCheckCompletedAt DateTime? @map("background_check_completed_at")
  hipaaTrainingAttestedAt DateTime? @map("hipaa_training_attested_at")
  confidentialityAgreementSignedAt DateTime? @map("confidentiality_agreement_signed_at")
  agencyApprovedAt  DateTime?     @map("agency_approved_at")
  agencyApprovedById String?        @map("agency_approved_by_id") @db.Uuid
  onboardingStatus  ProviderOnboardingStatus @default(PENDING) @map("onboarding_status")
  phiAccessApproved Boolean       @default(false) @map("phi_access_approved")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyApprovedBy  User?             @relation("TherapistApprovedBy", fields: [agencyApprovedById], references: [id], onDelete: SetNull)
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agencyLinks       AgencyTherapist[]
  appointments      Appointment[]
  sessions          Session[]
  treatmentPlans    TreatmentPlan[]
  documents         Document[]
  payouts           Payout[]
  reviews           Review[]
  providerBadges    ProviderBadge[]
  complaints        Complaint[]
  serviceLogs       ServiceLog[]
  insuranceClaims   InsuranceClaim[]
  marketplaceProfile ProviderMarketplaceProfile?

  @@index([tenantId])
  @@index([onboardingStatus])
  @@index([isVerified, isAcceptingClients])
  @@index([latitude, longitude])
  @@map("therapists")
}

model Agency {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String
  ein             String?
  npi             String?
  addressLine1    String?  @map("address_line1")
  addressLine2    String?  @map("address_line2")
  city            String?
  state           String?
  zipCode         String?  @map("zip_code")
  phone           String?
  email           String?
  website         String?
  isVerified      Boolean   @default(false) @map("is_verified")
  stripeAccountId String?   @map("stripe_account_id")
  baaSignedAt     DateTime? @map("baa_signed_at")
  baaDocumentKey  String?   @map("baa_document_key")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  therapists   AgencyTherapist[]
  appointments Appointment[]
  payouts      Payout[]
  marketplaceProfile ProviderMarketplaceProfile?

  @@index([tenantId])
  @@map("agencies")
}

model AgencyTherapist {
  id          String                @id @default(uuid()) @db.Uuid
  agencyId    String                @map("agency_id") @db.Uuid
  therapistId String                @map("therapist_id") @db.Uuid
  role        String                @default("THERAPIST")
  status      AgencyTherapistStatus @default(PENDING)
  joinedAt    DateTime?             @map("joined_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  agency    Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([agencyId, therapistId])
  @@index([agencyId])
  @@index([therapistId])
  @@map("agency_therapists")
}

// ---------------------------------------------------------------------------
// Scheduling & clinical sessions
// ---------------------------------------------------------------------------

model Appointment {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  childId         String            @map("child_id") @db.Uuid
  parentId        String            @map("parent_id") @db.Uuid
  therapistId     String            @map("therapist_id") @db.Uuid
  agencyId        String?           @map("agency_id") @db.Uuid
  therapyType     TherapyType       @map("therapy_type")
  status          AppointmentStatus @default(REQUESTED)
  scheduledStart  DateTime          @map("scheduled_start")
  scheduledEnd    DateTime          @map("scheduled_end")
  locationType    LocationType      @default(IN_HOME) @map("location_type")
  addressLine1    String?           @map("address_line1")
  addressLine2    String?           @map("address_line2")
  city            String?
  state           String?
  zipCode         String?           @map("zip_code")
  notes           String?
  cancelledReason String?           @map("cancelled_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  child            Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent           Parent            @relation(fields: [parentId], references: [id], onDelete: Cascade)
  therapist        Therapist         @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  agency           Agency?           @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  session          Session?
  telehealthSession TelehealthSession?

  @@index([tenantId])
  @@index([childId])
  @@index([parentId])
  @@index([therapistId])
  @@index([status])
  @@index([scheduledStart])
  @@map("appointments")
}

model Session {
  id              String        @id @default(uuid()) @db.Uuid
  appointmentId   String        @unique @map("appointment_id") @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  childId         String        @map("child_id") @db.Uuid
  therapistId     String        @map("therapist_id") @db.Uuid
  status          SessionStatus @default(SCHEDULED)
  checkInAt       DateTime?     @map("check_in_at")
  checkOutAt      DateTime?     @map("check_out_at")
