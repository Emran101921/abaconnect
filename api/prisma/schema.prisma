  zipCentroidLng      Decimal?            @map("zip_centroid_lng") @db.Decimal(10, 7)
  schedule            Json                @default("{}")
  languageRequirement String?             @map("language_requirement")
  employmentType      JobEmploymentType?  @map("employment_type")
  payRateMin          Decimal?            @map("pay_rate_min") @db.Decimal(10, 2)
  payRateMax          Decimal?            @map("pay_rate_max") @db.Decimal(10, 2)
  payRateDisplay      String?             @map("pay_rate_display")
  locationModality    JobLocationModality @default(IN_PERSON) @map("location_modality")
  requiredCredentials Json                @default("[]") @map("required_credentials")
  requiredExperience  String?             @map("required_experience")
  preferredStartDate  DateTime?           @map("preferred_start_date") @db.Date
  phiScanPassed       Boolean             @default(false) @map("phi_scan_passed")
  phiScanFlags        Json                @default("[]") @map("phi_scan_flags")
  publishedAt         DateTime?           @map("published_at")
  moderationNote      String?             @map("moderation_note")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency           Agency                    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  childServiceNeed ChildServiceNeed          @relation(fields: [childServiceNeedId], references: [id], onDelete: Cascade)
  applications     JobOpportunityApplication[]
  moderationFlags  PostingModerationFlag[]
  savedBy          SavedJobOpportunity[]
  invites          AgencyInviteToApply[]

  @@index([tenantId])
  @@index([agencyId])
  @@index([status])
  @@index([serviceType])
  @@index([zipCode])
  @@map("job_opportunities")
}

model JobOpportunityApplication {
  id                 String              @id @default(uuid()) @db.Uuid
  jobOpportunityId   String              @map("job_opportunity_id") @db.Uuid
  therapistId        String              @map("therapist_id") @db.Uuid
  applicantUserId    String              @map("applicant_user_id") @db.Uuid
  status             JobApplicationStatus @default(NEW_APPLICANT)
  message            String?
  credentialSnapshot Json                @default("{}") @map("credential_snapshot")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  jobOpportunity JobOpportunity           @relation(fields: [jobOpportunityId], references: [id], onDelete: Cascade)
  therapist      Therapist                @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  applicant      User                     @relation("JobApplicationApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  statusHistory  ApplicationStatusHistory[]
  interview      JobInterview?

  @@unique([jobOpportunityId, therapistId])
  @@index([jobOpportunityId])
  @@index([therapistId])
  @@index([status])
  @@map("job_opportunity_applications")
}

model JobInterview {
  id                        String             @id @default(uuid()) @db.Uuid
  tenantId                  String             @map("tenant_id") @db.Uuid
  agencyId                  String             @map("agency_id") @db.Uuid
  applicationId             String             @unique @map("application_id") @db.Uuid
  scheduledByUserId         String             @map("scheduled_by_user_id") @db.Uuid
  therapistUserId           String             @map("therapist_user_id") @db.Uuid
  scheduledAt               DateTime           @map("scheduled_at")
  durationMinutes           Int                @default(30) @map("duration_minutes")
  status                    JobInterviewStatus @default(SCHEDULED)
  recordingRequested        Boolean            @default(false) @map("recording_requested")
  agencyRecordingConsent    Boolean            @default(false) @map("agency_recording_consent")
  therapistRecordingConsent Boolean            @default(false) @map("therapist_recording_consent")
  notes                     String?
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency        Agency                    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  application   JobOpportunityApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledBy   User                      @relation("JobInterviewScheduler", fields: [scheduledByUserId], references: [id], onDelete: Restrict)
  therapistUser User                      @relation("JobInterviewTherapist", fields: [therapistUserId], references: [id], onDelete: Restrict)
  callSession   CallSession?

  @@index([tenantId])
  @@index([agencyId])
  @@index([therapistUserId])
  @@index([scheduledAt])
  @@index([status])
  @@map("job_interviews")
}

model ApplicationStatusHistory {
  id              String              @id @default(uuid()) @db.Uuid
  applicationId   String              @map("application_id") @db.Uuid
  fromStatus      JobApplicationStatus? @map("from_status")
  toStatus        JobApplicationStatus @map("to_status")
