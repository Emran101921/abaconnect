model EiBillingRecord {
  id                    String                  @id @default(uuid()) @db.Uuid
  tenantId              String                  @map("tenant_id") @db.Uuid
  agencyId              String                  @map("agency_id") @db.Uuid
  childId               String                  @map("child_id") @db.Uuid
  sessionId             String?                 @unique @map("session_id") @db.Uuid
  therapistId           String                  @map("therapist_id") @db.Uuid
  caseProfileId         String                  @map("case_profile_id") @db.Uuid
  queueStatus           EiBillingQueueStatus    @default(DRAFT_INCOMPLETE) @map("queue_status")
  units                 Decimal                 @default(0) @db.Decimal(8, 2)
  serviceDate           DateTime                @map("service_date") @db.Date
  startTime             DateTime?               @map("start_time")
  endTime               DateTime?               @map("end_time")
  validationSnapshot    Json                    @default("{}") @map("validation_snapshot")
  lockedAt              DateTime?               @map("locked_at")
  reviewedById          String?                 @map("reviewed_by_id") @db.Uuid
  reviewedAt            DateTime?               @map("reviewed_at")
  billedAmount          Decimal?                @map("billed_amount") @db.Decimal(10, 2)
  allowedAmount         Decimal?                @map("allowed_amount") @db.Decimal(10, 2)
  submittedAt           DateTime?               @map("submitted_at")
  externalReferenceId   String?                 @map("external_reference_id")
  clearinghouseWorkflow EiClearinghouseWorkflow? @map("clearinghouse_workflow")
  resubmissionOfId      String?                 @unique @map("resubmission_of_id") @db.Uuid
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency         Agency                  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  child          Child                   @relation(fields: [childId], references: [id], onDelete: Cascade)
  session        Session?                @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  therapist      Therapist               @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  caseProfile    EiCaseBillingProfile    @relation(fields: [caseProfileId], references: [id], onDelete: Restrict)
  reviewedBy     User?                   @relation("EiBillingReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  resubmissionOf EiBillingRecord?        @relation("EiBillingResubmission", fields: [resubmissionOfId], references: [id], onDelete: SetNull)
  resubmissions  EiBillingRecord?        @relation("EiBillingResubmission")
  validationIssues EiBillingValidationIssue[]
  denials        EiDenialRejection[]
  payments       EiPaymentPosting[]

  @@index([tenantId])
  @@index([agencyId])
  @@index([childId])
  @@index([therapistId])
  @@index([queueStatus])
  @@index([serviceDate])
  @@map("ei_billing_records")
}

model EiBillingValidationIssue {
  id           String   @id @default(uuid()) @db.Uuid
