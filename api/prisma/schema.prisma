  createdById   String?                @map("created_by_id") @db.Uuid
  publishedAt   DateTime?              @map("published_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?   @relation("ComplianceDocCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  acceptances ComplianceDocumentAcceptance[]

  @@unique([tenantId, documentType, version])
  @@index([tenantId, documentType, isActive])
  @@map("compliance_documents")
}

model ComplianceDocumentAcceptance {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  acceptedAt DateTime @default(now()) @map("accepted_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document ComplianceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([tenantId])
  @@index([documentId])
  @@map("compliance_document_acceptances")
}

model SecurityEvent {
  id        String                @id @default(uuid()) @db.Uuid
  tenantId  String?               @map("tenant_id") @db.Uuid
  userId    String?               @map("user_id") @db.Uuid
  eventType String                @map("event_type")
  severity  SecurityEventSeverity @default(INFO)
  ipAddress String?               @map("ip_address")
  userAgent String?               @map("user_agent")
  metadata  Json                  @default("{}")
  createdAt DateTime              @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("security_events")
}

model HipaaConsent {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  consentType String    @map("consent_type")
  version     String
  granted     Boolean   @default(true)
  grantedAt   DateTime  @default(now()) @map("granted_at")
  revokedAt   DateTime? @map("revoked_at")
  ipAddress   String?   @map("ip_address")
  signature   String?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([consentType])
  @@map("hipaa_consents")
}

/// Versioned Notice of Privacy Practices + Privacy Policy text (attorney-editable).
model PrivacyNoticeVersion {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String?  @map("tenant_id") @db.Uuid
  versionNumber     String   @map("version_number")
  title             String
  fullNoticeText    String   @map("full_notice_text") @db.Text
  privacyPolicyText String   @map("privacy_policy_text") @db.Text
  effectiveDate     DateTime @map("effective_date")
  isActive          Boolean  @default(false) @map("is_active")
  createdByUserId   String?  @map("created_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant          Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?                      @relation("NoticeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  acknowledgments HipaaNoticeAcknowledgment[]

  @@unique([tenantId, versionNumber])
  @@index([tenantId])
  @@index([isActive])
  @@map("privacy_notice_versions")
}

/// Proof of which notice version a user acknowledged (receipt, not waiver).
model HipaaNoticeAcknowledgment {
  id                         String   @id @default(uuid()) @db.Uuid
  tenantId                   String   @map("tenant_id") @db.Uuid
  userId                     String   @map("user_id") @db.Uuid
  noticeVersionId            String   @map("notice_version_id") @db.Uuid
  noticeVersion              String   @map("notice_version")
  acknowledgedAt             DateTime @default(now()) @map("acknowledged_at")
  ipAddress                  String?  @map("ip_address")
  userAgent                  String?  @map("user_agent")
  appVersion                 String?  @map("app_version")
  platform                   String?
  deviceId                   String?  @map("device_id")
  acknowledgmentTextSnapshot String   @map("acknowledgment_text_snapshot") @db.Text
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  noticeVersionRecord PrivacyNoticeVersion @relation(fields: [noticeVersionId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([userId])
  @@index([noticeVersionId])
  @@index([acknowledgedAt])
  @@map("hipaa_notice_acknowledgments")
}

/// Patient/user HIPAA rights requests (access, correction, restriction, etc.).
model PrivacyRightsRequest {
  id                       String                     @id @default(uuid()) @db.Uuid
  tenantId                 String                     @map("tenant_id") @db.Uuid
  userId                   String                     @map("user_id") @db.Uuid
  requestType              PrivacyRightsRequestType   @map("request_type")
  status                   PrivacyRightsRequestStatus @default(NEW)
  payload                  Json                       @default("{}")
  internalNotes            String?                    @map("internal_notes") @db.Text
  adminResponseDocumentKey String?                    @map("admin_response_document_key")
  ipAddress                String?                    @map("ip_address")
  userAgent                String?                    @map("user_agent")
  submittedAt              DateTime                   @default(now()) @map("submitted_at")
  completedAt              DateTime?                  @map("completed_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([requestType])
  @@map("privacy_rights_requests")
}

model AnalyticsSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  snapshotDate DateTime @map("snapshot_date") @db.Date
  metricKey    String   @map("metric_key")
  metricValue  Decimal  @map("metric_value") @db.Decimal(18, 4)
  dimensions   Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, snapshotDate, metricKey])
  @@index([tenantId])
  @@index([snapshotDate])
  @@index([metricKey])
  @@map("analytics_snapshots")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Anonymous provider marketplace (HIPAA-conscious service requests)
// ---------------------------------------------------------------------------

model MarketplaceRequest {
  id                       String                       @id @default(uuid()) @db.Uuid
  tenantId                 String                       @map("tenant_id") @db.Uuid
  childId                  String                       @map("child_id") @db.Uuid
  parentUserId             String                       @map("parent_user_id") @db.Uuid
  screeningResponseId      String?                      @map("screening_response_id") @db.Uuid
  anonymousPublicId        String                       @unique @map("anonymous_public_id")
  status                   MarketplaceRequestStatus     @default(DRAFT)
  serviceCategories        Json                         @default("[]") @map("service_categories")
  concernTags              Json                         @default("[]") @map("concern_tags")
  ageRange                 MarketplaceAgeRange          @map("age_range")
  zipCode                  String                       @map("zip_code")
  city                     String?
  state                    String?
  zipCentroidLat           Decimal                      @map("zip_centroid_lat") @db.Decimal(10, 7)
  zipCentroidLng           Decimal                      @map("zip_centroid_lng") @db.Decimal(10, 7)
  mapPinJitterLat          Decimal?                     @map("map_pin_jitter_lat") @db.Decimal(10, 7)
  mapPinJitterLng          Decimal?                     @map("map_pin_jitter_lng") @db.Decimal(10, 7)
  approximateLocationEnabled Boolean                    @default(true) @map("approximate_location_enabled")
  exactAddressShared       Boolean                      @default(false) @map("exact_address_shared")
  locationType             MarketplaceLocationType      @map("location_type")
  preferredSchedule        Json                         @default("{}") @map("preferred_schedule")
  languagePreference       String?                      @map("language_preference")
  authorizationStatus      MarketplaceAuthorizationStatus @map("authorization_status")
  urgency                  MarketplaceUrgency             @default(ROUTINE)
  publicDescription        String?                      @map("public_description")
  removedAt                DateTime?                    @map("removed_at")
  removedReason            String?                      @map("removed_reason")
  createdAt                DateTime                     @default(now()) @map("created_at")
  updatedAt                DateTime                     @updatedAt @map("updated_at")

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  child             Child                     @relation(fields: [childId], references: [id], onDelete: Cascade)
  parentUser        User                      @relation("MarketplaceRequestParentUser", fields: [parentUserId], references: [id], onDelete: Cascade)
  screeningResponse ScreeningResponse?        @relation(fields: [screeningResponseId], references: [id], onDelete: SetNull)
  interests         MarketplaceInterest[]
  consents          MarketplaceConsentRecord[]
  reports           MarketplaceReport[]

  @@index([tenantId])
  @@index([childId])
  @@index([parentUserId])
  @@index([status])
  @@index([zipCode])
  @@index([ageRange])
  @@index([authorizationStatus])
  @@map("marketplace_requests")
}

model MarketplaceInterest {
  id                   String                    @id @default(uuid()) @db.Uuid
  tenantId             String                    @map("tenant_id") @db.Uuid
  marketplaceRequestId String                    @map("marketplace_request_id") @db.Uuid
  providerProfileId    String                    @map("provider_profile_id") @db.Uuid
  message              String?
  availability         Json                      @default("{}")
  status               MarketplaceInterestStatus @default(PENDING_PARENT_REVIEW)
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marketplaceRequest MarketplaceRequest  @relation(fields: [marketplaceRequestId], references: [id], onDelete: Cascade)
  providerProfile    ProviderMarketplaceProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([marketplaceRequestId, providerProfileId])
  @@index([tenantId])
  @@index([providerProfileId])
  @@index([status])
  @@map("marketplace_interests")
}

model MarketplaceConsentRecord {
  id                   String                 @id @default(uuid()) @db.Uuid
  tenantId             String                 @map("tenant_id") @db.Uuid
  parentUserId         String                 @map("parent_user_id") @db.Uuid
  childId              String                 @map("child_id") @db.Uuid
  marketplaceRequestId String                 @map("marketplace_request_id") @db.Uuid
  providerProfileId    String?                @map("provider_profile_id") @db.Uuid
  consentType          MarketplaceConsentType @map("consent_type")
  consentTextVersion   String                 @map("consent_text_version")
  consentTextSnapshot  String                 @map("consent_text_snapshot") @db.Text
  granted              Boolean                @default(true)
  revokedAt            DateTime?              @map("revoked_at")
  ipAddress            String?                @map("ip_address")
  deviceInfo           String?                @map("device_info")
  createdAt            DateTime               @default(now()) @map("created_at")

  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentUser         User                       @relation("MarketplaceConsentParentUser", fields: [parentUserId], references: [id], onDelete: Cascade)
  child              Child                      @relation(fields: [childId], references: [id], onDelete: Cascade)
  marketplaceRequest MarketplaceRequest         @relation(fields: [marketplaceRequestId], references: [id], onDelete: Cascade)
  providerProfile    ProviderMarketplaceProfile? @relation(fields: [providerProfileId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([parentUserId])
  @@index([childId])
  @@index([marketplaceRequestId])
  @@index([providerProfileId])
  @@index([consentType])
  @@map("marketplace_consent_records")
}

model ProviderMarketplaceProfile {
  id                          String                              @id @default(uuid()) @db.Uuid
  tenantId                    String                              @map("tenant_id") @db.Uuid
  userId                      String                              @unique @map("user_id") @db.Uuid
  accountType                 ProviderMarketplaceAccountType      @map("account_type")
  therapistId                 String?                             @unique @map("therapist_id") @db.Uuid
  agencyId                    String?                             @unique @map("agency_id") @db.Uuid
  legalName                   String                              @map("legal_name")
  displayName                 String                              @map("display_name")
  licenseNumber               String?                             @map("license_number")
  npi                         String?
  serviceCategories           Json                                @default("[]") @map("service_categories")
  coverageZipCodes            Json                                @default("[]") @map("coverage_zip_codes")
  languages                   Json                                @default("[]")
  availability                Json                                @default("{}")
  verifiedStatus              ProviderMarketplaceVerificationStatus @default(PENDING) @map("verified_status")
  confidentialityTermsAccepted Boolean                            @default(false) @map("confidentiality_terms_accepted")
  confidentialityAcceptedAt   DateTime?                           @map("confidentiality_accepted_at")
  suspendedAt                 DateTime?                           @map("suspended_at")
  createdAt                   DateTime                            @default(now()) @map("created_at")
  updatedAt                   DateTime                            @updatedAt @map("updated_at")

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  therapist  Therapist?          @relation(fields: [therapistId], references: [id], onDelete: SetNull)
  agency     Agency?             @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  interests  MarketplaceInterest[]
  consents   MarketplaceConsentRecord[]

  @@index([tenantId])
  @@index([verifiedStatus])
  @@map("provider_marketplace_profiles")
}

model MarketplaceSavedSearch {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  name       String
  filters    Json     @default("{}")
  alertsEnabled Boolean @default(true) @map("alerts_enabled")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("marketplace_saved_searches")
}

model MarketplaceReport {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  reporterUserId       String   @map("reporter_user_id") @db.Uuid
  marketplaceRequestId String?  @map("marketplace_request_id") @db.Uuid
  reportedUserId       String?  @map("reported_user_id") @db.Uuid
  reason               String
  details              String?
  status               String   @default("OPEN")
  createdAt            DateTime @default(now()) @map("created_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reporter           User                @relation("MarketplaceReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  marketplaceRequest MarketplaceRequest? @relation(fields: [marketplaceRequestId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@map("marketplace_reports")
}
