// ---------------------------------------------------------------------------
// Multi-tenant
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  domain    String?  @unique
  settings  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  parents              Parent[]
  children             Child[]
  therapists           Therapist[]
  agencies             Agency[]
  appointments         Appointment[]
  sessions             Session[]
  documents            Document[]
  messageThreads       MessageThread[]
  notifications        Notification[]
  payments             Payment[]
  payouts              Payout[]
  insuranceClaims      InsuranceClaim[]
  complaints           Complaint[]
  disputes             Dispute[]
  auditLogs            AuditLog[]
  hipaaConsents        HipaaConsent[]
  privacyNoticeVersions PrivacyNoticeVersion[]
  hipaaNoticeAcknowledgments HipaaNoticeAcknowledgment[]
  privacyRightsRequests PrivacyRightsRequest[]
  analyticsSnapshots   AnalyticsSnapshot[]
  screeningTemplates   ScreeningTemplate[]
  screeningResponses   ScreeningResponse[]
  treatmentPlans       TreatmentPlan[]
  telehealthSessions   TelehealthSession[]
  locationEvents       LocationEvent[]
  serviceLogs          ServiceLog[]
  providerBadges       ProviderBadge[]
  securityEvents       SecurityEvent[]
  complianceDocuments  ComplianceDocument[]
  complianceDocumentAcceptances ComplianceDocumentAcceptance[]
  claimEditHistories   ClaimEditHistory[]
  marketplaceRequests  MarketplaceRequest[]
  marketplaceInterests MarketplaceInterest[]
  marketplaceConsents  MarketplaceConsentRecord[]
  providerMarketplaceProfiles ProviderMarketplaceProfile[]
  marketplaceSavedSearches MarketplaceSavedSearch[]
  marketplaceReports   MarketplaceReport[]
  callSessions         CallSession[]
  callAuditLogs        CallAuditLog[]
  callNotifications    CallNotification[]
  jobOpportunities     JobOpportunity[]
  jobInterviews        JobInterview[]
  jobMarketplaceAuditLogs MarketplaceAuditLog[]
  agencyCaseloadChildren AgencyCaseloadChild[]
  eiBillingRecords       EiBillingRecord[]
  eiClearinghouseConfigs EiClearinghouseConfig[]
  eiAgencyBillingProfiles EiAgencyBillingProfile[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Users & profiles
// ---------------------------------------------------------------------------

model User {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  email           String
  passwordHash    String    @map("password_hash")
  role            UserRole
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?
  avatarUrl       String?   @map("avatar_url")
  isActive        Boolean   @default(true) @map("is_active")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  mfaSecret       String?   @map("mfa_secret")
  mfaEnabled      Boolean   @default(false) @map("mfa_enabled")
  tokenVersion        Int       @default(0) @map("token_version")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  refreshTokens         RefreshToken[]
  securityEvents        SecurityEvent[]
  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent                Parent?
  therapist             Therapist?
  devices               UserDevice[]
  authDevices           AuthDevice[]
  sentMessages          Message[]             @relation("MessageSender")
  messageParticipants   MessageParticipant[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  hipaaConsents         HipaaConsent[]
  hipaaNoticeAcknowledgments HipaaNoticeAcknowledgment[]
  privacyRightsRequests PrivacyRightsRequest[]
  privacyNoticeVersionsCreated PrivacyNoticeVersion[] @relation("NoticeCreatedBy")
  documentAccessLogs    DocumentAccessLog[]
  authoredSoapNotes     SoapNote[]            @relation("SoapNoteAuthor")
  authoredProgressNotes ProgressNote[]        @relation("ProgressNoteAuthor")
  authoredTreatmentPlans TreatmentPlan[]      @relation("TreatmentPlanAuthor")
  reviewsWritten        Review[]              @relation("ReviewAuthor")
  complaintsFiled       Complaint[]           @relation("ComplaintReporter")
  complaintsAssigned    Complaint[]           @relation("ComplaintAssignee")
  disputesOpened        Dispute[]             @relation("DisputeOpener")
  complianceDocumentsCreated ComplianceDocument[] @relation("ComplianceDocCreatedBy")
  complianceDocumentAcceptances ComplianceDocumentAcceptance[]
  claimsCreated         InsuranceClaim[]      @relation("ClaimCreatedBy")
  claimsSubmitted       InsuranceClaim[]      @relation("ClaimSubmittedBy")
  claimEdits            ClaimEditHistory[]    @relation("ClaimEditor")
  therapistsApproved    Therapist[]           @relation("TherapistApprovedBy")
  marketplaceRequestsCreated MarketplaceRequest[] @relation("MarketplaceRequestParentUser")
  marketplaceConsentsGranted MarketplaceConsentRecord[] @relation("MarketplaceConsentParentUser")
  providerMarketplaceProfile ProviderMarketplaceProfile?
  marketplaceSavedSearches MarketplaceSavedSearch[]
  marketplaceReportsFiled MarketplaceReport[] @relation("MarketplaceReportReporter")
  agencyId                String?               @map("agency_id") @db.Uuid
  agency                  Agency?               @relation("AgencyAdminUsers", fields: [agencyId], references: [id], onDelete: SetNull)
  createdById             String?               @map("created_by_id") @db.Uuid
  createdBy               User?                 @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  usersCreated            User[]                @relation("UserCreatedBy")
  uploadedAgencyDocuments AgencyDocument[]
  agencyRosterEntries     AgencyRoster[]        @relation("AgencyRosterUser")
  agencyRosterAdded       AgencyRoster[]        @relation("AgencyRosterAddedBy")
  scAssignmentsAsCoordinator ChildServiceCoordinatorAssignment[] @relation("ScCoordinator")
  scAssignmentsMade       ChildServiceCoordinatorAssignment[] @relation("ScAssignedBy")
  eiInitialScreenings     EiInitialScreening[]
  eiOngoingScreenings     EiOngoingScreening[]
  serviceCoordinationNotes ServiceCoordinationNote[]
  callSessionsInitiated    CallSession[]       @relation("CallInitiator")
  callParticipants         CallParticipant[]
  callAuditLogsAsActor     CallAuditLog[]      @relation("CallAuditActor")
  callAuditLogsAsTarget    CallAuditLog[]      @relation("CallAuditTarget")
  callNotifications        CallNotification[]
  childServiceNeedsCreated ChildServiceNeed[]  @relation("ChildServiceNeedCreator")
  jobApplicationsSubmitted JobOpportunityApplication[] @relation("JobApplicationApplicant")
  applicationStatusChanges ApplicationStatusHistory[]
  jobInterviewsScheduled   JobInterview[]              @relation("JobInterviewScheduler")
  jobInterviewsAsTherapist JobInterview[]              @relation("JobInterviewTherapist")
  postingModerationFlags   PostingModerationFlag[]
  agencyInvitesToApply     AgencyInviteToApply[] @relation("AgencyInviteSender")
  jobMarketplaceAuditLogs  MarketplaceAuditLog[]
  agencyCaseloadEnrollments AgencyCaseloadChild[] @relation("AgencyCaseloadEnrolledBy")
  eiBillingRecordsReviewed  EiBillingRecord[]     @relation("EiBillingReviewedBy")
  eiDenialsAssigned         EiDenialRejection[]     @relation("EiDenialAssignedStaff")
  eiPaymentsPosted          EiPaymentPosting[]      @relation("EiPaymentPostedBy")
  eiValidationIssuesResolved  EiBillingValidationIssue[] @relation("EiValidationResolvedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([role])
  @@index([agencyId])
  @@map("users")
}

model UserDevice {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  deviceToken String   @map("device_token")
  platform    String
  appVersion  String?  @map("app_version")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceToken])
  @@index([userId])
  @@map("user_devices")
}

/// Tracks the physical devices a user authenticates from for MFA/security.
/// Distinct from UserDevice (push tokens): this powers new-device detection,
/// device-bound MFA, and IP/location stamping of auth events.
model AuthDevice {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  deviceId      String    @map("device_id")
  deviceModel   String?   @map("device_model")
  platform      String?
  osVersion     String?   @map("os_version")
  trusted       Boolean   @default(false)
  lastIp        String?   @map("last_ip")
  lastLocation  String?   @map("last_location")
  lastLatitude  Decimal?  @map("last_latitude") @db.Decimal(10, 7)
  lastLongitude Decimal?  @map("last_longitude") @db.Decimal(10, 7)
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt    DateTime  @default(now()) @map("last_seen_at")
  mfaVerifiedAt DateTime? @map("mfa_verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("auth_devices")
}

model Parent {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @map("user_id") @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  addressLine1           String?  @map("address_line1")
  addressLine2           String?  @map("address_line2")
  city                   String?
  state                  String?
  zipCode                String?  @map("zip_code")
  latitude               Decimal? @db.Decimal(10, 7)
  longitude              Decimal? @db.Decimal(10, 7)
  emergencyContactName   String?  @map("emergency_contact_name")
  emergencyContactPhone  String?  @map("emergency_contact_phone")
  insuranceProvider      String?  @map("insurance_provider")
  insuranceMemberId      String?  @map("insurance_member_id")
  insuranceGroupNumber   String?  @map("insurance_group_number")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  children             Child[]
  appointments         Appointment[]
  screeningResponses   ScreeningResponse[]
  payments             Payment[]
  insuranceClaims      InsuranceClaim[]
  reviews              Review[]
  complaints           Complaint[]
  disputes             Dispute[]
  eiInitialScreenings  EiInitialScreening[]
  eiOngoingScreenings  EiOngoingScreening[]
  serviceCoordinationNotes ServiceCoordinationNote[]
  agencyCaseloadFor        Agency[] @relation("AgencyCaseloadParent")

  @@index([tenantId])
  @@map("parents")
}

// PHI fields on Child: guardianPhone, guardianEmail, addressLine1, zipCode,
// pediatricianName, insuranceType (see AuditService for access logging).
model Child {
  id             String   @id @default(uuid()) @db.Uuid
  parentId       String   @map("parent_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  dateOfBirth    DateTime @map("date_of_birth") @db.Date
  gender         String?
  primaryLanguage       String?  @map("primary_language")
  guardianName          String?  @map("guardian_name")
  guardianPhone         String?  @map("guardian_phone")
  guardianEmail         String?  @map("guardian_email")
  addressLine1          String?  @map("address_line1")
  zipCode               String?  @map("zip_code")
  pediatricianName      String?  @map("pediatrician_name")
  insuranceType         String?  @map("insurance_type")
  hadEarlyIntervention  Boolean? @map("had_early_intervention")
  diagnosisCodes String[] @default([]) @map("diagnosis_codes")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  parent             Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments       Appointment[]
  sessions           Session[]
  screeningResponses ScreeningResponse[]
  treatmentPlans     TreatmentPlan[]
  documents          Document[]
  insuranceClaims    InsuranceClaim[]
  serviceLogs        ServiceLog[]
  marketplaceRequests MarketplaceRequest[]
  marketplaceConsents MarketplaceConsentRecord[]
  scAssignments       ChildServiceCoordinatorAssignment[]
  eiInitialScreenings EiInitialScreening[]
  eiOngoingScreenings EiOngoingScreening[]
  serviceCoordinationNotes ServiceCoordinationNote[]
  callSessions             CallSession[]
  serviceNeeds             ChildServiceNeed[]
  agencyCaseloadEnrollments AgencyCaseloadChild[]
  eiCaseBillingProfiles     EiCaseBillingProfile[]
  eiBillingRecords          EiBillingRecord[]

  ageRange           MarketplaceAgeRange? @map("age_range")
  city               String?
  state              String?

  @@index([parentId])
  @@index([tenantId])
  @@map("children")
}

// ---------------------------------------------------------------------------
// Screenings
// ---------------------------------------------------------------------------

model ScreeningTemplate {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  name         String
  description  String?
  therapyType  TherapyType @map("therapy_type")
  questions    Json        @default("[]")
  scoringRules Json        @default("{}") @map("scoring_rules")
  version      Int         @default(1)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responses ScreeningResponse[]

  @@index([tenantId])
  @@index([therapyType])
  @@map("screening_templates")
}

model ScreeningResponse {
  id               String    @id @default(uuid()) @db.Uuid
  templateId       String    @map("template_id") @db.Uuid
  childId          String    @map("child_id") @db.Uuid
  parentId         String    @map("parent_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  responses        Json      @default("{}")
  score            Decimal?  @db.Decimal(8, 2)
  riskLevel        String?   @map("risk_level")
  recommendations  Json      @default("[]")
  isDraft          Boolean   @default(false) @map("is_draft")
  consentGrantedAt       DateTime? @map("consent_granted_at")
  evaluationRequestedAt  DateTime? @map("evaluation_requested_at")
  concernTags            Json      @default("[]") @map("concern_tags")
  suggestedServiceCategories Json @default("[]") @map("suggested_service_categories")
  disclaimerAccepted     Boolean   @default(false) @map("disclaimer_accepted")
  completedAt            DateTime  @default(now()) @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  template ScreeningTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  child    Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
